<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数列パズル：ペンギンのおさんぽ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700&display=swap');
        
        :root {
            --sky-blue: #e0f2fe;
            --ice-blue: #7dd3fc;
            --deep-blue: #0369a1;
            --penguin-black: #334155;
        }

        body {
            background-color: var(--sky-blue);
            background-image: radial-gradient(#bae6fd 1px, transparent 1px);
            background-size: 20px 20px;
            color: var(--penguin-black);
            font-family: 'Zen Maru Gothic', sans-serif;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .main-card {
            background: white;
            border-radius: 2rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            border: 6px solid white;
        }

        .ice-button {
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 1.25rem;
            transition: all 0.2s ease;
            box-shadow: 0 4px 0 #e2e8f0;
            text-align: center;
            padding: 1.25rem;
            font-size: 1.1rem;
        }

        .ice-button:hover:not(:disabled) {
            transform: translateY(-2px);
            background: #f0f9ff;
            border-color: var(--ice-blue);
            box-shadow: 0 6px 0 var(--ice-blue);
        }

        .ice-button:active:not(:disabled) {
            transform: translateY(2px);
            box-shadow: none;
        }

        .ice-button:disabled {
            cursor: default;
        }

        .progress-track {
            background: #f1f5f9;
            border-radius: 999px;
            height: 10px;
            overflow: hidden;
        }

        .progress-fill {
            background: linear-gradient(90deg, #38bdf8, #818cf8);
            border-radius: 999px;
            transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .math-bubble {
            background: #ecfeff;
            color: #0891b2;
            padding: 2px 10px;
            border-radius: 999px;
            font-weight: bold;
            display: inline-block;
        }

        .info-panel {
            background: #f0fdf4;
            border: 2px solid #bbf7d0;
            padding: 1.25rem;
            border-radius: 1rem;
            margin-top: 1rem;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .penguin-emoji {
            font-size: 3rem;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .correct-pop {
            animation: pop 0.4s ease-out;
        }

        @keyframes pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.02); }
            100% { transform: scale(1); }
        }

        .hidden { display: none; }

        .btn-next {
            background: #0ea5e9;
            color: white;
            font-weight: bold;
            padding: 0.8rem 2.5rem;
            border-radius: 999px;
            box-shadow: 0 4px 0 #0369a1;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-next:hover {
            background: #0284c7;
            transform: translateY(-2px);
            box-shadow: 0 6px 0 #0369a1;
        }

        .btn-next:active {
            transform: translateY(2px);
            box-shadow: none;
        }
    </style>
</head>
<body class="p-4">
    <div class="w-full max-w-2xl">
        <!-- Header -->
        <div class="text-center mb-6">
            <div class="penguin-emoji mb-2">🐧</div>
            <h1 class="text-2xl font-bold text-slate-700">ペンギンのおさんぽパズル</h1>
            <p class="text-sm text-slate-500 font-medium">等差数列のリズムをつかんで、おうちに帰ろう</p>
        </div>

        <!-- Main Game -->
        <div id="game-ui" class="main-card p-6 md:p-10 relative">
            <div class="flex items-center justify-between mb-6">
                <span id="level-label" class="text-xs font-bold bg-sky-100 text-sky-600 px-3 py-1 rounded-full uppercase tracking-widest">STEP 01</span>
                <div class="w-32">
                    <div class="progress-track">
                        <div id="progress-bar" class="progress-fill" style="width: 20%;"></div>
                    </div>
                </div>
            </div>

            <div class="mb-8">
                <h2 id="level-title" class="text-xl font-bold mb-4 text-slate-800">氷の板をならべよう</h2>
                <div class="bg-slate-50 rounded-2xl p-6 text-slate-700 border border-slate-100 shadow-inner">
                    <p id="problem-text" class="text-lg leading-relaxed">
                        <!-- Problems load here -->
                    </p>
                </div>
            </div>

            <div id="choices-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Choices load here -->
            </div>

            <!-- Feedback & Next Action Area -->
            <div id="action-area" class="mt-8 hidden">
                <div id="feedback-bubble" class="text-lg font-bold text-center mb-4"></div>
                
                <div id="math-info" class="info-panel mb-6">
                    <div class="font-bold text-emerald-700 mb-2 flex items-center gap-2">
                        <span>📝</span> 数学のポイント解説
                    </div>
                    <div id="info-content" class="text-sm text-emerald-800 leading-relaxed">
                        <!-- Info details load here -->
                    </div>
                </div>

                <div class="flex justify-center">
                    <button id="next-btn" class="btn-next">
                        つぎのステップへ ➔
                    </button>
                </div>
            </div>

            <div id="status-hint" class="mt-8 h-12 flex items-center justify-center text-sm font-bold text-slate-400 italic">
                正しい氷（答え）をえらんでクリックしてね
            </div>
        </div>

        <!-- Result Screen -->
        <div id="final-ui" class="main-card p-10 text-center hidden">
            <div class="text-6xl mb-6">🏠✨🐧</div>
            <h2 class="text-3xl font-bold text-slate-800 mb-4">ゴールおめでとう！</h2>
            <p class="text-slate-500 mb-8 leading-relaxed">
                ペンギンさんは無事におうちにたどり着きました。<br>
                等差数列の「初項」と「公差」を完璧にマスターしたね！
            </p>
            <button onclick="location.reload()" class="bg-sky-500 hover:bg-sky-400 text-white font-bold py-4 px-10 rounded-2xl transition-all shadow-lg shadow-sky-200">
                もういっかい挑戦する
            </button>
        </div>
    </div>

    <script>
        const missions = [
            {
                level: 1,
                title: "氷の板をならべよう",
                problem: "ペンギンさんが歩く氷の板に番号が書いてあるよ。<br>【3, 7, 11...】と続いているね。<br>次の一歩は、前の数字に『いくつ』足せばいいかな？",
                mathPoint: "最初の数（<strong>初項 a</strong>）は 3、増えている数（<strong>公差 d</strong>）は 4 だね。",
                options: [
                    { text: "4をたす", correct: true, feedback: "せいかい！リズムがつかめてきたね。" },
                    { text: "3をたす", correct: false, feedback: "おしい！3から7になるには、いくつ増えてるかな？" },
                    { text: "7をたす", correct: false, feedback: "それは2つめの氷の番号だよ。間の数を見てみて。" },
                    { text: "5をたす", correct: false, feedback: "ちょっとジャンプしすぎちゃったかも。" }
                ]
            },
            {
                level: 2,
                title: "とびいしのパズル",
                problem: "最初の氷（初項 a）は <span class='math-bubble'>5</span> 番、4つめの氷は <span class='math-bubble'>17</span> 番だよ。<br>一歩ずつ、同じ数だけ増えるとしたら、その数はいくつかな？",
                mathPoint: "初項 a = 5、第4項 a₄ = 17。<br>3回ジャンプして 12 増えたから、12 ÷ 3 = 4（<strong>公差 d = 4</strong>）だね。",
                options: [
                    { text: "4ずつ増える", correct: true, feedback: "すごい！ジャンプの間隔（回数）を正しく計算できたね。" },
                    { text: "3ずつ増える", correct: false, feedback: "4つめの板まで、ジャンプは3回するんだよ。" },
                    { text: "12ずつ増える", correct: false, feedback: "それは4つめまでの「合計」の増えた数だね。" },
                    { text: "2ずつ増える", correct: false, feedback: "もう少し大きなリズムで歩いてみよう。" }
                ]
            },
            {
                level: 3,
                title: "くだり坂のステップ",
                problem: "今度は数字が小さくなっていくよ。1番目（初項）は <span class='math-bubble'>20</span>、3番目は <span class='math-bubble'>14</span> だよ。<br>n 番目の数字を求める「一般項 aₙ」の式はどれかな？",
                mathPoint: "初項 a = 20、公差 d = -3。<br><strong>一般項 aₙ = 20 + (n-1)×(-3) = -3n + 23</strong> になるよ。",
                options: [
                    { text: "-3n + 23", correct: true, feedback: "せいかい！この式（一般項）があれば、どんな遠くの板もわかるよ。" },
                    { text: "3n + 17", correct: false, feedback: "これだと数字が増えちゃうね。マイナスの公差を考えて。" },
                    { text: "-6n + 26", correct: false, feedback: "一歩で減る数を見つけてみて。1番目は20になるかな？" },
                    { text: "-3n + 20", correct: false, feedback: "n=1 のときに 20 になるように調整が必要だよ。" }
                ]
            },
            {
                level: 4,
                title: "エレベーターのゆくえ",
                problem: "1番目（初項）が <span class='math-bubble'>-10</span>、6番目が <span class='math-bubble'>0</span> のリズムだよ。<br>このまま進んで、10番目の氷の番号を当ててみて！",
                mathPoint: "初項 a = -10、公差 d = 2。<br><strong>第10項 a₁₀ = -10 + (10-1)×2 = 8</strong> だね。",
                options: [
                    { text: "8", correct: true, feedback: "バッチリ！2ずつ増えるリズムを見抜いたね。" },
                    { text: "10", correct: false, feedback: "おしい！ジャンプの回数は (10-1)回、つまり9回分だよ。" },
                    { text: "0", correct: false, feedback: "それは6番目の番号だね。もっと先まで歩いていこう。" },
                    { text: "2", correct: false, feedback: "それは1回に増える数（公差）だね。" }
                ]
            },
            {
                level: 5,
                title: "さいごの魔法",
                problem: "ついにお家が見えてきた！<br>1番目が <span class='math-bubble'>1</span>、100番目が <span class='math-bubble'>199</span> の数列だよ。<br>ぜんぶの氷に共通する「一般項 aₙ」の式はどれ？",
                mathPoint: "初項 a = 1、公差 d = 2。<br><strong>aₙ = 1 + (n-1)×2 = 2n - 1</strong> です。お見事！",
                options: [
                    { text: "2n - 1", correct: true, feedback: "大せいかい！ペンギンさんはお家に帰れたよ！" },
                    { text: "2n + 1", correct: false, feedback: "n=1 を代入すると、初項が 3 になっちゃうよ。" },
                    { text: "n + 99", correct: false, feedback: "これだと 100番目は 199 になるけど、初項が合わないね。" },
                    { text: "199n", correct: false, feedback: "これだと数字がどんどん巨大になっちゃうよ！" }
                ]
            }
        ];

        let currentLevel = 0;

        function loadMission() {
            const mission = missions[currentLevel];
            const gameUi = document.getElementById('game-ui');
            gameUi.classList.remove('correct-pop');

            document.getElementById('level-label').innerText = `STEP ${String(mission.level).padStart(2, '0')}`;
            document.getElementById('level-title').innerText = mission.title;
            document.getElementById('problem-text').innerHTML = mission.problem;
            
            const progress = ((currentLevel + 1) / missions.length) * 100;
            document.getElementById('progress-bar').style.width = `${progress}%`;
            
            const grid = document.getElementById('choices-grid');
            grid.innerHTML = '';
            
            mission.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'ice-button text-slate-700 font-bold';
                btn.innerText = opt.text;
                btn.onclick = () => checkAnswer(opt, btn);
                grid.appendChild(btn);
            });
            
            document.getElementById('action-area').classList.add('hidden');
            document.getElementById('status-hint').classList.remove('hidden');
            document.getElementById('math-info').classList.remove('hidden');
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function checkAnswer(option, element) {
            const actionArea = document.getElementById('action-area');
            const feedbackBubble = document.getElementById('feedback-bubble');
            const infoContent = document.getElementById('info-content');
            const statusHint = document.getElementById('status-hint');
            const mission = missions[currentLevel];

            if (option.correct) {
                document.getElementById('game-ui').classList.add('correct-pop');
                statusHint.classList.add('hidden');
                actionArea.classList.remove('hidden');
                document.getElementById('math-info').classList.remove('hidden');
                document.getElementById('next-btn').classList.remove('hidden');
                
                feedbackBubble.innerText = "✨ " + option.feedback;
                feedbackBubble.className = 'text-lg font-bold text-center mb-4 text-sky-600';
                
                infoContent.innerHTML = mission.mathPoint;

                const buttons = document.querySelectorAll('.ice-button');
                buttons.forEach(b => {
                    b.disabled = true;
                    if (b !== element) b.style.opacity = "0.3";
                });
                element.style.background = "#e0f2fe";
                element.style.borderColor = "#38bdf8";
                element.style.boxShadow = "none";
                element.style.transform = "translateY(2px)";

                document.getElementById('next-btn').onclick = () => {
                    currentLevel++;
                    if (currentLevel < missions.length) {
                        loadMission();
                    } else {
                        showFinal();
                    }
                };
            } else {
                feedbackBubble.innerText = "❌ " + option.feedback;
                feedbackBubble.className = 'text-md font-bold text-center mb-4 text-orange-500';
                element.style.background = "#fff7ed";
                element.style.borderColor = "#fdba74";
                
                statusHint.classList.add('hidden');
                actionArea.classList.remove('hidden');
                document.getElementById('math-info').classList.add('hidden');
                document.getElementById('next-btn').classList.add('hidden');
                
                setTimeout(() => {
                    if (!actionArea.classList.contains('hidden') && document.getElementById('next-btn').classList.contains('hidden')) {
                        actionArea.classList.add('hidden');
                        statusHint.classList.remove('hidden');
                        element.style.background = "#f8fafc";
                        element.style.borderColor = "#e2e8f0";
                    }
                }, 1500);
            }
        }

        function showFinal() {
            document.getElementById('game-ui').classList.add('hidden');
            document.getElementById('final-ui').classList.remove('hidden');
        }

        window.onload = loadMission;
    </script>
</body>
</html>
